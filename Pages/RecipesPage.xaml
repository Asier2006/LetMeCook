<?xml version="1.0" encoding="utf-8" ?>
<!-- Vista de creación básica de receta. Los pasos/vídeos se crean en la opción avanzada Let me Cook. -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.RecipesPage">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="16">
                <Label Text="Crear nueva receta"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Label Text="Campos obligatorios" FontAttributes="Bold" TextColor="#9C40F7" FontSize="18" />

                <Entry x:Name="NombreEntry"
                       Placeholder="Nombre del plato *"
                       FontSize="18" />

                <Editor x:Name="DescripcionEntry"
                        Placeholder="Descripción del plato *"
                        FontSize="18"
                        AutoSize="TextChanges"
                        HeightRequest="110" />

                <Entry x:Name="ComensalesEntry"
                       Placeholder="Comensales *"
                       FontSize="18"
                       Keyboard="Numeric" />

                <Label Text="Imagen del plato" FontAttributes="Bold" FontSize="18" />
                <Image x:Name="ImagenPreview"
                       HeightRequest="180"
                       BackgroundColor="#DDDDDD"
                       Aspect="AspectFill" />
                <Button Text="Seleccionar imagen (+1 punto)"
                        BackgroundColor="#9C40F7"
                        TextColor="White"
                        CornerRadius="10"
                        Clicked="SeleccionarImagenClicked" />

                <Label Text="Campos opcionales (+1 punto cada bloque rellenado)" FontAttributes="Bold" TextColor="#4CAF50" FontSize="18" />

                <Entry x:Name="TiempoEntry"
                       Placeholder="Tiempo de preparación en minutos (+1)"
                       FontSize="18"
                       Keyboard="Numeric" />

                <Label Text="Origen / nacionalidad (+1)" FontAttributes="Bold" />
                <Entry x:Name="OrigenEntry"
                       Placeholder="Buscar origen: es → España"
                       FontSize="18"
                       TextChanged="OnOrigenTextChanged" />
                <FlexLayout x:Name="OrigenTagsLayout" Wrap="Wrap" Direction="Row" />
                <CollectionView ItemsSource="{Binding OrigenSugerencias}" HeightRequest="70" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#6A0DAD" Padding="10,5" Margin="3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnOrigenSugerenciaTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}" TextColor="White" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Tipo de cocina (+1)" FontAttributes="Bold" />
                <Entry x:Name="TipoCocinaEntry"
                       Placeholder="Buscar tipo: hor → Horno"
                       FontSize="18"
                       TextChanged="OnTipoCocinaTextChanged" />
                <FlexLayout x:Name="TipoCocinaTagsLayout" Wrap="Wrap" Direction="Row" />
                <CollectionView ItemsSource="{Binding TipoCocinaSugerencias}" HeightRequest="70" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#6A0DAD" Padding="10,5" Margin="3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTipoCocinaSugerenciaTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}" TextColor="White" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Ingredientes (+1)" FontAttributes="Bold" />
                <Entry x:Name="IngredienteEntry"
                       Placeholder="Buscar ingrediente: man → Manzana"
                       FontSize="18"
                       TextChanged="OnIngredienteTextChanged" />
                <FlexLayout x:Name="IngredienteTagsLayout" Wrap="Wrap" Direction="Row" />
                <CollectionView ItemsSource="{Binding IngredienteSugerencias}" HeightRequest="70" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#6A0DAD" Padding="10,5" Margin="3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnIngredienteSugerenciaTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}" TextColor="White" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="¿Contiene este alérgeno?" FontAttributes="Bold" VerticalOptions="Center" FontSize="18" />
                <CollectionView ItemsSource="{Binding Alergenos}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <HorizontalStackLayout Spacing="10" Padding="10">
                                <CheckBox IsChecked="{Binding Seleccion}" VerticalOptions="Center" />
                                <Label Text="{Binding Nombre}" FontSize="18" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="¿Es apto para esta preferencia?" FontAttributes="Bold" VerticalOptions="Center" FontSize="18" />
                <CollectionView ItemsSource="{Binding Preferencias}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <HorizontalStackLayout Spacing="10" Padding="10">
                                <CheckBox IsChecked="{Binding Seleccion}" VerticalOptions="Center" />
                                <Label Text="{Binding Nombre}" FontSize="18" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Text="Crear"
                            Grid.Column="0"
                            BackgroundColor="#555"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"
                            Clicked="GuardarRecetaClicked" />

                    <Button Text="Let me Cook"
                            Grid.Column="1"
                            BackgroundColor="#9C40F7"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"
                            FontAttributes="Bold"
                            Clicked="LetMeCookClicked" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="BottomBar"
              Grid.Row="1"
              BackgroundColor="#9C40F7"
              HeightRequest="65"
              Padding="5"
              ColumnDefinitions="*,*,*"
              VerticalOptions="End">

            <Button Grid.Column="0"
                    Text="Inicio"
                    TextColor="Black"
                    ImageSource="home.png"
                    BackgroundColor="#9C40F7"
                    Clicked="InicioClicked" />

            <Button Grid.Column="1"
                    Text="Recetas"
                    TextColor="Black"
                    ImageSource="recipes.png"
                    BackgroundColor="#9C40F7"
                    Clicked="RecetasClicked" />

            <Button Grid.Column="2"
                    Text="Perfil"
                    TextColor="Black"
                    ImageSource="user.png"
                    BackgroundColor="#9C40F7"
                    Clicked="PerfilClicked" />
        </Grid>
    </Grid>
</ContentPage>
