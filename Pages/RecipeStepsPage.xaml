<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.RecipeStepsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1E1E1E">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔶 NOMBRE DE LA RECETA -->
        <Label x:Name="TituloLabel"
               Grid.Row="0"
               FontSize="32"
               FontAttributes="Bold"
               TextColor="#FAC26C"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               Margin="20,20,20,10" />

        <!-- 🔶 CONTENEDOR DE PASOS -->
        <ScrollView Grid.Row="1"
                    VerticalScrollBarVisibility="Always">
            <VerticalStackLayout x:Name="PasosContainer"
                                 Padding="20"
                                 Spacing="25" />
        </ScrollView>

        <!-- 🔶 BOTÓN FINAL -->
        <Grid Grid.Row="2"
              BackgroundColor="#FAC26C"
              Padding="10"
              HeightRequest="70">
            <Button Text="Completado"
                    BackgroundColor="#E09A3F"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    FontSize="18"
                    Clicked="OnCompletadoClicked" />
        </Grid>
    </Grid>
</ContentPage>

