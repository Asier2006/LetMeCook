<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.HomePage">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔶 BARRA SUPERIOR (FILTROS) -->
        <VerticalStackLayout x:Name="TopBar"
                             BackgroundColor="#FAC26C"
                             Padding="10"
                             Grid.Row="0">

            <!-- 🔶 BOTÓN BUSCAR CON FILTROS -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="#E0A85A"
                    HeightRequest="45"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnToggleFiltros" />
                </Border.GestureRecognizers>

                <Label Text="🔍 Buscar con filtros..."
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="18"
                       VerticalOptions="Center"
                       Padding="15,0" />
            </Border>

            <!-- 🔶 PANEL DE FILTROS -->
            <VerticalStackLayout x:Name="PanelFiltros"
                                 IsVisible="False"
                                 Spacing="10"
                                 Padding="5,10">

                <FlexLayout x:Name="TagsLayout"
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Center" />

                <!-- CAMPOS DE FILTRO -->
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                    <Entry x:Name="EntryComensales"
                           Placeholder="Comensales"
                           PlaceholderColor="White"
                           TextColor="White"
                           Keyboard="Numeric"
                           Completed="OnFiltroEntryCompleted" />
                </Border>

                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                    <Entry x:Name="EntryTiempo"
                           Placeholder="Tiempo de preparación (min)"
                           PlaceholderColor="White"
                           TextColor="White"
                           Keyboard="Numeric"
                           Completed="OnFiltroEntryCompleted" />
                </Border>

                <!-- ORIGEN -->
                <Label Text="Origen / nacionalidad"
                       TextColor="White"
                       FontAttributes="Bold" />

                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                    <Entry x:Name="EntryOrigen"
                           Placeholder="Buscar origen: es → España"
                           PlaceholderColor="White"
                           TextColor="White"
                           TextChanged="OnOrigenTextChanged"
                           Completed="OnFiltroEntryCompleted" />
                </Border>

                <FlexLayout x:Name="OrigenTagsLayout" Wrap="Wrap" Direction="Row" />

                <!-- SUGERENCIAS ORIGEN -->
                <CollectionView ItemsSource="{Binding OrigenSugerencias}"
                                HeightRequest="70"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#D18F4F"
                                    Padding="10,5"
                                    Margin="3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnOrigenSugerenciaTapped" />
                                </Border.GestureRecognizers>

                                <Label Text="{Binding .}"
                                       TextColor="White"
                                       FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- TIPO DE COCINA -->
                <Label Text="Tipo de cocina"
                       TextColor="White"
                       FontAttributes="Bold" />

                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                    <Entry x:Name="EntryTipoCocina"
                           Placeholder="Buscar tipo: hor → Horno"
                           PlaceholderColor="White"
                           TextColor="White"
                           TextChanged="OnTipoCocinaTextChanged"
                           Completed="OnFiltroEntryCompleted" />
                </Border>

                <FlexLayout x:Name="TipoCocinaTagsLayout" Wrap="Wrap" Direction="Row" />

                <!-- INGREDIENTES -->
                <Label Text="Ingredientes"
                       TextColor="White"
                       FontAttributes="Bold" />

                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                    <Entry x:Name="EntryIngrediente"
                           Placeholder="Buscar ingrediente: man → Manzana"
                           PlaceholderColor="White"
                           TextColor="White"
                           TextChanged="OnIngredienteTextChanged"
                           Completed="OnFiltroEntryCompleted" />
                </Border>

                <FlexLayout x:Name="IngredienteTagsLayout" Wrap="Wrap" Direction="Row" />

                <!-- BOTONES DE FILTRO -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,5,0,0">
                    <Button Text="Buscar"
                            BackgroundColor="#D18F4F"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="15"
                            Grid.Column="0"
                            Clicked="OnBuscarClicked" />

                    <Button x:Name="BtnTogglePreferencias"
                            Text="Desactivar filtros preferencias"
                            BackgroundColor="#B57A3F"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="15"
                            FontSize="11"
                            Grid.Column="1"
                            Clicked="OnTogglePreferenciasClicked" />
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>

        <!-- 🔶 LISTA DE RECETAS -->
        <CollectionView ItemsSource="{Binding Recetas}"
                x:Name="ListaRecetas"
                Grid.Row="1"
                Margin="20,20,20,20">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- 🔶 MARCO DE LA RECETA (SIN HeightRequest FIJO) -->
                    <Border StrokeThickness="0"
                    BackgroundColor="#FAC26C"
                    StrokeShape="RoundRectangle 20"
                    Padding="15"
                    Margin="30,35"
                    VerticalOptions="Start">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRecetaTapped" />
                        </Border.GestureRecognizers>

                        <!-- GRID CON 3 FILAS: USUARIO / SEPARADOR / CONTENIDO -->
                        <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,*">

                            <!-- 🔶 FOTO + NOMBRE EN EL MISMO MARCO (CLICK FUNCIONAL) -->
                            <Border Grid.Row="0"
                            Grid.ColumnSpan="2"
                            BackgroundColor="#E0A85A"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 15"
                            Padding="10"
                            HorizontalOptions="Fill"
                            VerticalOptions="Start">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                Tapped="OnCreatorClicked"
                                CommandParameter="{Binding UsuarioId}" />
                                </Border.GestureRecognizers>

                                <HorizontalStackLayout Spacing="10">

                                    <!-- FOTO DE PERFIL REDONDA -->
                                    <Frame HeightRequest="70"
                                   WidthRequest="70"
                                   Padding="0"
                                   CornerRadius="100"
                                   IsClippedToBounds="True"
                                   BackgroundColor="Transparent">

                                        <Image Source="{Binding CreadorFotoSource}"
                                               
                                       Aspect="AspectFill" />
                                    </Frame>

                                    <!-- NOMBRE DEL USUARIO -->
                                    <Label Text="{Binding CreadorNombre}"
                                   TextColor="White"
                                           FontSize="24"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />

                                </HorizontalStackLayout>

                            </Border>

                            <!-- 🔶 SEPARADOR BLANCO COMPLETO ENTRE USUARIO Y CONTENIDO -->
                            <BoxView Grid.Row="1"
                             Grid.ColumnSpan="2"
                             HeightRequest="1"
                             BackgroundColor="White"
                             Margin="0,10,0,10"
                             HorizontalOptions="Fill" />

                            <!-- 🔶 IMAGEN DE LA RECETA (VERTICAL + SEPARADA + SIN SOLAPAR) -->
                            <Frame Grid.Row="2"
                           Grid.Column="0"
                           Padding="0"
                           CornerRadius="8"
                           IsClippedToBounds="True"
                           HeightRequest="290"
                           WidthRequest="170"
                           Margin="0,0,0,12"
                           VerticalOptions="Start">

                                <Image Source="{Binding ImagenSource}"
                               Aspect="AspectFill" />
                            </Frame>

                            <!-- 🔶 INFO DE LA RECETA (ALINEADA CON LA IMAGEN) -->
                            <VerticalStackLayout Grid.Row="2"
                                         Grid.Column="1"
                                         Padding="10,0"
                                         Spacing="12"
                                         VerticalOptions="Start"
                                         Margin="0,0,0,12">

                                <!-- TÍTULO -->
                                <Label Text="{Binding Titulo}"
                               FontAttributes="Bold"
                               TextColor="White"
                               FontSize="24" />

                                <!-- COMENSALES -->
                                <HorizontalStackLayout Spacing="8">
                                    <Image Source="userR.png"
                                   HeightRequest="34"
                                   WidthRequest="34"
                                   VerticalOptions="Center" />
                                    <Label Text="Comensales:"
                                           FontSize="17"
                                   TextColor="White"
                                   FontAttributes="Bold" />
                                    <Label Text="{Binding Comensales}"
                                   TextColor="White"
                                           FontSize="17"/>
                                </HorizontalStackLayout>

                                <!-- TIEMPO -->
                                <HorizontalStackLayout Spacing="8">
                                    <Image Source="clock.png"
                                   HeightRequest="34"
                                   WidthRequest="34"
                                   VerticalOptions="Center" />
                                    <Label Text="Tiempo:"
                                           FontSize="17"
                                   TextColor="White"
                                   FontAttributes="Bold" />
                                    <Label Text="{Binding TiempoPreparacion, StringFormat='{0} min'}"
                                   TextColor="White"
                                           FontSize="17"/>
                                    
                                </HorizontalStackLayout>

                                <!-- COCINA -->
                                <HorizontalStackLayout Spacing="8">
                                    <Image Source="oven.png"
                                   HeightRequest="34"
                                   WidthRequest="34"
                                   VerticalOptions="Center" />
                                    <Label Text="Cocina:"
                                   TextColor="White"
                                           FontSize="17"
                                   FontAttributes="Bold" />
                                    <Label Text="{Binding TipoCocina}"
                                   TextColor="White"
                                           FontSize="17"/>
                                    
                                </HorizontalStackLayout>

                                <!-- 🔶 SEPARADOR BLANCO ENTRE BLOQUES -->
                                <BoxView HeightRequest="1"
                                 BackgroundColor="White"
                                 Margin="0,10"
                                 HorizontalOptions="Fill" />

                                <!-- ORIGEN -->
                                <HorizontalStackLayout Spacing="8">
                                    <Image Source="world.png"
                                   HeightRequest="34"
                                   WidthRequest="34"
                                   VerticalOptions="Center" />
                                    <Label Text="Origen:"
                                   TextColor="White"
                                           FontSize="17"
                                   FontAttributes="Bold" />
                                    <Label Text="{Binding OrigenDelPlato}"
                                   TextColor="White"
                                           FontSize="17"/>
                                    
                                </HorizontalStackLayout>

                                <!-- INGREDIENTES -->
                                <HorizontalStackLayout Spacing="8">
                                    <Image Source="fork.png"
                                   HeightRequest="34"
                                   WidthRequest="34"
                                   VerticalOptions="Center" />
                                    <Label Text="Ingrediente:"
                                   TextColor="White"
                                           FontSize="17"
                                   FontAttributes="Bold" />
                                    <Label Text="{Binding IngredientePrincipal}"
                                   TextColor="White"
                                           FontSize="17"
                                   LineBreakMode="WordWrap" />
                                </HorizontalStackLayout>

                                <!-- LIKE + ESTRELLA -->
                                <HorizontalStackLayout Spacing="20"
                                               Margin="0,10,0,0"
                                               VerticalOptions="End"
                                               HorizontalOptions="End">

                                    <VerticalStackLayout>
                                        <Image Source="{Binding IconoLike}"
                                       HeightRequest="22"
                                       WidthRequest="22">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="LikeClicked" />
                                            </Image.GestureRecognizers>
                                        </Image>

                                        <Label Text="{Binding Likes}"
                                       FontSize="12"
                                       TextColor="White"
                                       HorizontalOptions="Center" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout>
                                        <Image Source="{Binding IconoEstrella}"
                                       HeightRequest="22"
                                       WidthRequest="22">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="PuntuarClicked" />
                                            </Image.GestureRecognizers>
                                        </Image>
                                    </VerticalStackLayout>

                                </HorizontalStackLayout>

                            </VerticalStackLayout>

                        </Grid>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>


        <!-- 🔶 BARRA INFERIOR -->
        <Grid x:Name="BottomBar"
      Grid.Row="2"
      BackgroundColor="#FAC26C"
      HeightRequest="70"
      Padding="0"
      ColumnDefinitions="*,*,*"
      VerticalOptions="End">

            <!-- BOTÓN INICIO -->
            <Button x:Name="BtnInicio"
            Grid.Column="0"
            ImageSource="lmchouse.png"
            BackgroundColor="#FAC26C"
            CornerRadius="35"
            Padding="10"
            WidthRequest="60"
            HeightRequest="60"
            Clicked="InicioClicked"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

            <!-- BOTÓN RECETAS -->
            <Button x:Name="BtnRecetas"
            Grid.Column="1"
            ImageSource="lmcrecipe.png"
            BackgroundColor="#FAC26C"
            CornerRadius="35"
            Padding="10"
            WidthRequest="60"
            HeightRequest="60"
            Clicked="RecetasClicked"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

            <!-- BOTÓN PERFIL -->
            <Button x:Name="BtnPerfil"
            Grid.Column="2"
            ImageSource="lmcprofile.png"
            BackgroundColor="#FAC26C"
            CornerRadius="35"
            Padding="10"
            WidthRequest="60"
            HeightRequest="60"
            Clicked="PerfilClicked"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

        </Grid>



    </Grid>

</ContentPage>
