<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.HomePage">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- BARRA SUPERIOR (FILTROS + BÚSQUEDA GLOBAL) -->
        <ScrollView Grid.Row="0"
            Orientation="Vertical"
            VerticalScrollBarVisibility="Always"
            BackgroundColor="Transparent">

            <VerticalStackLayout x:Name="TopBar"
                         BackgroundColor="#fff2db"
                         Padding="10">

                <!-- ENTRY DE BÚSQUEDA GLOBAL -->
                <Border StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                BackgroundColor="#E0A85A"
                HeightRequest="45"
                VerticalOptions="Center">

                    <Entry x:Name="EntryBusquedaGlobal"
                   Placeholder="Buscar recetas, ingredientes, origen..."
                   PlaceholderColor="Gray"
                   TextColor="Black"
                   
                   FontSize="18"
                   TextChanged="OnBusquedaGlobalChanged"
                   Focused="OnToggleFiltros" />
                </Border>

                <!-- PANEL DE FILTROS -->
                <VerticalStackLayout x:Name="PanelFiltros"
                             IsVisible="False"
                             Spacing="10"
                             Padding="5,10">

                    <!-- BOTÓN ATRÁS -->
                    <Frame HeightRequest="20"
                        WidthRequest="20"
                        Padding="0"
                        CornerRadius="40"
                        IsClippedToBounds="True"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">

                        <ImageButton Source="back.png"
                        BackgroundColor="Transparent"
                        Aspect="AspectFill"
                        Clicked="OnCerrarFiltrosClicked" />
                   
                    </Frame>


                    <!-- 🔶 TAGS GENERALES -->
                    <FlexLayout x:Name="TagsLayout"
                        Wrap="Wrap"
                        Direction="Row"
                        JustifyContent="Start"
                        AlignItems="Center" />

                    <!-- CAMPOS DE FILTRO -->
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                        <Entry x:Name="EntryComensales"
                       Placeholder="Comensales"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       Keyboard="Numeric"
                       Completed="OnFiltroEntryCompleted" />
                    </Border>

                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                        <Entry x:Name="EntryTiempo"
                       Placeholder="Tiempo de preparación (min)"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       Keyboard="Numeric"
                       Completed="OnFiltroEntryCompleted" />
                    </Border>

                    <!-- ORIGEN -->
                    <Label Text="Origen / nacionalidad"
                   TextColor="black"
                   FontAttributes="Bold" />

                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                        <Entry x:Name="EntryOrigen"
                       Placeholder="Buscar origen: es → España"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       TextChanged="OnOrigenTextChanged"
                       Completed="OnFiltroEntryCompleted" />
                    </Border>

                    <FlexLayout x:Name="OrigenTagsLayout" Wrap="Wrap" Direction="Row" />

                    <!-- SUGERENCIAS ORIGEN -->
                    <CollectionView ItemsSource="{Binding OrigenSugerencias}"
                            HeightRequest="70"
                            SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#FAC26C"
                                Padding="10,5"
                                Margin="3">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnOrigenSugerenciaTapped" />
                                    </Border.GestureRecognizers>

                                    <Label Text="{Binding .}"
                                   TextColor="White"
                                   FontSize="12" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- TIPO DE COCINA -->
                    <Label Text="Tipo de cocina"
                   TextColor="black"
                   FontAttributes="Bold" />

                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                        <Entry x:Name="EntryTipoCocina"
                       Placeholder="Buscar tipo: hor → Horno"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       TextChanged="OnTipoCocinaTextChanged"
                       Completed="OnFiltroEntryCompleted" />
                    </Border>

                    <FlexLayout x:Name="TipoCocinaTagsLayout" Wrap="Wrap" Direction="Row" />

                    <CollectionView ItemsSource="{Binding TipoCocinaSugerencias}"
                        HeightRequest="70"
                        SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="#FAC26C"
                                        Padding="10,5"
                                        Margin="3">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTipoCocinaSugerenciaTapped" />
                                    </Border.GestureRecognizers>

                                    <Label Text="{Binding .}"
                                               TextColor="White"
                                               FontSize="12" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    
                    
                    <!-- INGREDIENTES -->
                    <Label Text="Ingredientes"
                   TextColor="black"
                   FontAttributes="Bold" />

                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E0A85A" Padding="5">
                        <Entry x:Name="EntryIngrediente"
                       Placeholder="Buscar ingrediente: man → Manzana"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       TextChanged="OnIngredienteTextChanged"
                       Completed="OnFiltroEntryCompleted" />
                    </Border>

                    <FlexLayout x:Name="IngredienteTagsLayout" Wrap="Wrap" Direction="Row" />

                    <!-- SUGERENCIAS INGREDIENTES -->
                    <CollectionView ItemsSource="{Binding IngredienteSugerencias}"
                         HeightRequest="70"
                         SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="#FAC26C"
                                        Padding="10,5"
                                        Margin="3">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnIngredienteSugerenciaTapped" />
                                    </Border.GestureRecognizers>

                                    <Label Text="{Binding .}"
                                           TextColor="White"
                                           FontSize="12" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- BOTONES DE FILTRO -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,5,0,0">
                        <Button Text="Buscar"
                        BackgroundColor="#D18F4F"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="15"
                        Grid.Column="0"
                        Clicked="OnBuscarClicked" />

                        <Button x:Name="BtnTogglePreferencias"
                        Text="Desactivar filtros preferencias"
                        BackgroundColor="#B57A3F"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="15"
                        FontSize="11"
                        Grid.Column="1"
                        Clicked="OnTogglePreferenciasClicked" />
                    </Grid>

                </VerticalStackLayout>
            </VerticalStackLayout>

        </ScrollView>



        <!-- CAMBIOOOOOOOOOOOOOOOOOOOOOOOO -->
        <!-- 🔶 LISTA DE RECETAS -->
        <CollectionView ItemsSource="{Binding Recetas}"
                x:Name="ListaRecetas"
                Grid.Row="1"
                Margin="20,20,20,20">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- 🔶 MARCO DE LA RECETA -->
                    <Border StrokeThickness="0"
                    BackgroundColor="#FAC26C"
                    StrokeShape="RoundRectangle 20"
                    Padding="10"
                    Margin="10,15"
                    VerticalOptions="Start">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRecetaTapped" />
                        </Border.GestureRecognizers>

                        <!-- GRID CON 3 FILAS: USUARIO / SEPARADOR / CONTENIDO -->
                        <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*">

                            <!-- 🔶 CABECERA DEL CREADOR CON LIKE + ESTRELLA A LA DERECHA -->
                            <Border Grid.Row="0"
                            BackgroundColor="#E0A85A"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 15"
                            Padding="10"
                            HorizontalOptions="Fill"
                            VerticalOptions="Start">

                                <Grid ColumnDefinitions="Auto,*,Auto"
                              VerticalOptions="Center">

                                    <!-- FOTO + NOMBRE (CLICK PERFIL) -->
                                    <Grid Grid.Column="0">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer 
                                        Tapped="OnCreatorClicked"
                                        CommandParameter="{Binding UsuarioId}" />
                                        </Grid.GestureRecognizers>

                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">

                                            <Frame HeightRequest="55"
                                           WidthRequest="55"
                                           Padding="0"
                                           CornerRadius="100"
                                           IsClippedToBounds="True"
                                           BackgroundColor="Transparent">

                                                <Image Source="{Binding CreadorFotoSource}"
                                               Aspect="AspectFill" />
                                            </Frame>

                                            <Label Text="{Binding CreadorNombre}"
                                           TextColor="White"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />

                                        </HorizontalStackLayout>
                                    </Grid>

                                    <!-- ESPACIADOR TRANSPARENTE -->
                                    <BoxView Grid.Column="1" BackgroundColor="Transparent" />

                                    <!-- LIKE + ESTRELLA -->
                                    <HorizontalStackLayout Grid.Column="2"
                                                   Spacing="20"
                                                   VerticalOptions="Center">

                                        <!-- LIKE -->
                                        <VerticalStackLayout>
                                            <Image Source="{Binding IconoLike}"
                                           HeightRequest="26"
                                           WidthRequest="26">
                                                <Image.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="LikeClicked" />
                                                </Image.GestureRecognizers>
                                            </Image>

                                            <Label Text="{Binding Likes}"
                                           FontSize="12"
                                           TextColor="White"
                                           HorizontalOptions="Center" />
                                        </VerticalStackLayout>

                                        <!-- ESTRELLA -->
                                        <VerticalStackLayout>
                                            <Image Source="{Binding IconoEstrella}"
                                           HeightRequest="26"
                                           WidthRequest="26">
                                                <Image.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="PuntuarClicked" />
                                                </Image.GestureRecognizers>
                                            </Image>
                                        </VerticalStackLayout>

                                    </HorizontalStackLayout>

                                </Grid>
                            </Border>

                            <!-- 🔶 SEPARADOR -->
                            <BoxView Grid.Row="1"
                             HeightRequest="1"
                             BackgroundColor="White"
                             Margin="0,10" />

                            <!-- 🔶 CONTENIDO (TÍTULO + IMAGEN HORIZONTAL + INFO DEBAJO) -->
                            <VerticalStackLayout Grid.Row="2"
                     Spacing="10"
                     VerticalOptions="Start">

                                <!-- 🔶 TÍTULO DE LA RECETA (IZQUIERDA Y SIMÉTRICO) -->
                                <Label Text="{Binding Titulo}"
           FontAttributes="Bold"
           TextColor="White"
           FontSize="22"
           HorizontalOptions="Start"
           LineBreakMode="WordWrap"
           Margin="5,8,0,8" />

                                <!-- IMAGEN HORIZONTAL MÁS COMPACTA -->
                                <Frame Padding="0"
           CornerRadius="12"
           IsClippedToBounds="True"
           HeightRequest="180"
           HorizontalOptions="Fill">
                                    <Image Source="{Binding ImagenSource}"
               Aspect="AspectFill" />
                                </Frame>

                                <!-- 🔶 SEPARADOR ENTRE IMAGEN Y COMENSALES -->
                                <BoxView HeightRequest="1"
             BackgroundColor="White"
             Margin="0,5" />

                                <!-- INFO EN COLUMNA -->
                                <VerticalStackLayout Spacing="10">

                                    <!-- COMENSALES -->
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                        <Image Source="userR.png"
                   HeightRequest="26"
                   WidthRequest="26" />
                                        <Label Text="Comensales:"
                   FontSize="16"
                   TextColor="White"
                   FontAttributes="Bold" />
                                        <Label Text="{Binding Comensales}"
                   TextColor="White"
                   FontSize="16" />
                                    </HorizontalStackLayout>

                                    <!-- TIEMPO -->
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                        <Image Source="clock.png"
                   HeightRequest="26"
                   WidthRequest="26" />
                                        <Label Text="Tiempo:"
                   FontSize="16"
                   TextColor="White"
                   FontAttributes="Bold" />
                                        <Label Text="{Binding TiempoPreparacion, StringFormat='{0} min'}"
                   TextColor="White"
                   FontSize="16" />
                                    </HorizontalStackLayout>

                                    <!-- COCINA -->
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                        <Image Source="oven.png"
                   HeightRequest="26"
                   WidthRequest="26" />
                                        <Label Text="{Binding TipoCocinaPrincipal, StringFormat='Cocina: {0}'}"
                   TextColor="White"
                   FontSize="16"
                   FontAttributes="Bold"
                   LineBreakMode="WordWrap" />
                                    </HorizontalStackLayout>

                                    <!-- SEPARADOR -->
                                    <BoxView HeightRequest="1"
                 BackgroundColor="White"
                 Margin="0,8" />

                                    <!-- ORIGEN -->
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                        <Image Source="world.png"
                   HeightRequest="26"
                   WidthRequest="26" />
                                        <Label Text="{Binding OrigenPrincipal, StringFormat='Origen: {0}'}"
                   TextColor="White"
                   FontSize="16"
                   FontAttributes="Bold"
                   LineBreakMode="WordWrap" />
                                    </HorizontalStackLayout>

                                    <!-- INGREDIENTE -->
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                        <Image Source="fork.png"
                   HeightRequest="26"
                   WidthRequest="26" />
                                        <Label Text="{Binding IngredientePrincipalSimple, StringFormat='Ingrediente: {0}'}"
                   TextColor="White"
                   FontSize="16"
                   FontAttributes="Bold"
                   LineBreakMode="WordWrap" />
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>

                            </VerticalStackLayout>



                        </Grid>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!--  AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA  -->





        <!-- 🔶 BARRA INFERIOR -->
        <Grid x:Name="BottomBar"
      Grid.Row="2"
      BackgroundColor="#FAC26C"
      HeightRequest="70"
      Padding="0"
      ColumnDefinitions="*,*,*"
      VerticalOptions="End">

            <!-- BOTÓN INICIO -->
            <Button x:Name="BtnInicio"
            Grid.Column="0"
            ImageSource="lmchouse.png"
            BackgroundColor="#FAC26C"
            CornerRadius="35"
            Padding="10"
            WidthRequest="60"
            HeightRequest="60"
            Clicked="InicioClicked"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

            <!-- BOTÓN RECETAS -->
            <Button x:Name="BtnRecetas"
            Grid.Column="1"
            ImageSource="lmcrecipe.png"
            BackgroundColor="#FAC26C"
            CornerRadius="35"
            Padding="10"
            WidthRequest="60"
            HeightRequest="60"
            Clicked="RecetasClicked"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

            <!-- BOTÓN PERFIL -->
            <Button x:Name="BtnPerfil"
            Grid.Column="2"
            ImageSource="lmcprofile.png"
            BackgroundColor="#FAC26C"
            CornerRadius="35"
            Padding="10"
            WidthRequest="60"
            HeightRequest="60"
            Clicked="PerfilClicked"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

        </Grid>



    </Grid>

</ContentPage>
