<?xml version="1.0" encoding="utf-8" ?>
<!-- Vista principal con listado de recetas, buscador por filtros, etiquetas seleccionables, likes y valoración. -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.HomePage">
    <Grid RowDefinitions="Auto,*,Auto">

        <VerticalStackLayout x:Name="TopBar"
                              BackgroundColor="#9C40F7"
                              Padding="10"
                              Grid.Row="0">

            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="#7A1CCF"
                    HeightRequest="40"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnToggleFiltros" />
                </Border.GestureRecognizers>
                <Label Text="🔍 Buscar con filtros..."
                       TextColor="White"
                       FontSize="18"
                       VerticalOptions="Center"
                       Padding="15,0" />
            </Border>

            <VerticalStackLayout x:Name="PanelFiltros" IsVisible="False" Spacing="8" Padding="5,10">

                <FlexLayout x:Name="TagsLayout"
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Center" />

                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#7A1CCF" Padding="5">
                    <Entry x:Name="EntryComensales"
                           Placeholder="Comensales"
                           PlaceholderColor="#CCA0F0"
                           TextColor="White"
                           Keyboard="Numeric"
                           Completed="OnFiltroEntryCompleted" />
                </Border>

                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#7A1CCF" Padding="5">
                    <Entry x:Name="EntryTiempo"
                           Placeholder="Tiempo de preparación (min)"
                           PlaceholderColor="#CCA0F0"
                           TextColor="White"
                           Keyboard="Numeric"
                           Completed="OnFiltroEntryCompleted" />
                </Border>

                <Label Text="Origen / nacionalidad" TextColor="White" FontAttributes="Bold" />
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#7A1CCF" Padding="5">
                    <Entry x:Name="EntryOrigen"
                           Placeholder="Buscar origen: es → España"
                           PlaceholderColor="#CCA0F0"
                           TextColor="White"
                           TextChanged="OnOrigenTextChanged"
                           Completed="OnFiltroEntryCompleted" />
                </Border>
                <FlexLayout x:Name="OrigenTagsLayout" Wrap="Wrap" Direction="Row" />
                <CollectionView ItemsSource="{Binding OrigenSugerencias}" HeightRequest="70" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#6A0DAD" Padding="10,5" Margin="3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnOrigenSugerenciaTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}" TextColor="White" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Tipo de cocina" TextColor="White" FontAttributes="Bold" />
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#7A1CCF" Padding="5">
                    <Entry x:Name="EntryTipoCocina"
                           Placeholder="Buscar tipo: hor → Horno"
                           PlaceholderColor="#CCA0F0"
                           TextColor="White"
                           TextChanged="OnTipoCocinaTextChanged"
                           Completed="OnFiltroEntryCompleted" />
                </Border>
                <FlexLayout x:Name="TipoCocinaTagsLayout" Wrap="Wrap" Direction="Row" />
                <CollectionView ItemsSource="{Binding TipoCocinaSugerencias}" HeightRequest="70" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#6A0DAD" Padding="10,5" Margin="3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTipoCocinaSugerenciaTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}" TextColor="White" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Ingredientes" TextColor="White" FontAttributes="Bold" />
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#7A1CCF" Padding="5">
                    <Entry x:Name="EntryIngrediente"
                           Placeholder="Buscar ingrediente: man → Manzana"
                           PlaceholderColor="#CCA0F0"
                           TextColor="White"
                           TextChanged="OnIngredienteTextChanged"
                           Completed="OnFiltroEntryCompleted" />
                </Border>
                <FlexLayout x:Name="IngredienteTagsLayout" Wrap="Wrap" Direction="Row" />
                <CollectionView ItemsSource="{Binding IngredienteSugerencias}" HeightRequest="70" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="#6A0DAD" Padding="10,5" Margin="3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnIngredienteSugerenciaTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}" TextColor="White" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,5,0,0">
                    <Button Text="Buscar"
                            BackgroundColor="#6A0DAD"
                            TextColor="White"
                            CornerRadius="15"
                            Grid.Column="0"
                            Clicked="OnBuscarClicked" />
                    <Button x:Name="BtnTogglePreferencias"
                            Text="Desactivar filtros preferencias"
                            BackgroundColor="#444"
                            TextColor="White"
                            CornerRadius="15"
                            FontSize="11"
                            Grid.Column="1"
                            Clicked="OnTogglePreferenciasClicked" />
                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <CollectionView ItemsSource="{Binding Recetas}" x:Name="ListaRecetas" Grid.Row="1">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="0" BackgroundColor="#9C40F7" StrokeShape="RoundRectangle 15" Padding="10" Margin="20,20" HeightRequest="240">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRecetaTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, *">
                            <StackLayout Orientation="Horizontal" Spacing="10" Grid.Row="0">
                                <Image Source="{Binding CreadorFotoSource}"
                                       HeightRequest="40"
                                       WidthRequest="40"
                                       Aspect="AspectFill"/>
                                <Button Text="{Binding CreadorNombre}"
                                        CommandParameter="{Binding UsuarioId}"
                                        BackgroundColor="Transparent"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Clicked="OnCreatorClicked"/>
                            </StackLayout>

                            <Image Source="{Binding ImagenSource}"
                                   Grid.Row="1"
                                   Grid.Column="0"
                                   Aspect="AspectFill"
                                   HeightRequest="140"
                                   WidthRequest="140" />

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Padding="10,0" Spacing="4">
                                <Label Text="{Binding Titulo}" FontAttributes="Bold" TextColor="White" FontSize="18" />
                                <Label Text="{Binding Comensales, StringFormat='Comensales: {0}'}" TextColor="White"/>
                                <Label Text="{Binding TiempoPreparacion, StringFormat='Tiempo: {0} min'}" TextColor="White" />
                                <Label Text="{Binding TipoCocina, StringFormat='Cocina: {0}'}" TextColor="White" />
                                <Label Text="{Binding OrigenDelPlato, StringFormat='Origen: {0}'}" TextColor="White" />
                                <Label Text="{Binding IngredientePrincipal, StringFormat='Ingredientes: {0}'}" LineBreakMode="WordWrap" TextColor="White" />

                                <HorizontalStackLayout Spacing="15" Margin="0,5,0,0" VerticalOptions="End" HorizontalOptions="End">
                                    <VerticalStackLayout>
                                        <Image Source="{Binding IconoLike}"
                                               HeightRequest="20"
                                               WidthRequest="20"
                                               Aspect="AspectFit">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="LikeClicked" />
                                            </Image.GestureRecognizers>
                                        </Image>

                                        <Label Text="{Binding Likes}"
                                               FontSize="12"
                                               TextColor="White"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Image Source="{Binding IconoEstrella}"
                                               HeightRequest="20"
                                               WidthRequest="20"
                                               Aspect="AspectFit">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="PuntuarClicked" />
                                            </Image.GestureRecognizers>
                                        </Image>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid x:Name="BottomBar"
              Grid.Row="2"
              BackgroundColor="#9C40F7"
              HeightRequest="65"
              Padding="5"
              ColumnDefinitions="*,*,*"
              VerticalOptions="End">

            <Button Grid.Column="0"
                    Text="Inicio"
                    TextColor="Black"
                    ImageSource="home.png"
                    BackgroundColor="#9C40F7"
                    Clicked="InicioClicked" />

            <Button Grid.Column="1"
                    Text="Recetas"
                    TextColor="Black"
                    ImageSource="recipes.png"
                    BackgroundColor="#9C40F7"
                    Clicked="RecetasClicked" />

            <Button Grid.Column="2"
                    Text="Perfil"
                    TextColor="Black"
                    ImageSource="user.png"
                    BackgroundColor="#9C40F7"
                    Clicked="PerfilClicked" />
        </Grid>
    </Grid>
</ContentPage>
