<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.SettingsView">

    <VerticalStackLayout Spacing="12">

        <Button Text="Cambiar nombre de usuario"
                BackgroundColor="#C87F2F"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="50"
                Clicked="CambiarUsernameClicked" />

        <Button Text="Cambiar email"
                BackgroundColor="#C87F2F"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="50"
                Clicked="CambiarEmailClicked" />

        <Button Text="Cambiar contraseña"
                BackgroundColor="#C87F2F"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="50"
                Clicked="CambiarPasswordClicked" />

        <Button Text="Cambiar preferencias"
                BackgroundColor="#C87F2F"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="50"
                Clicked="CambiarPreferenciasClicked" />

        <Button Text="Cerrar sesión"
                BackgroundColor="#C87F2F"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="50"
                Clicked="CerrarSesionClicked" />

    </VerticalStackLayout>
</ContentView>
