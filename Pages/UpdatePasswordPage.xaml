<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.UpdatePasswordPage"
             BackgroundColor="#FAC26C">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Cambiar contraseña"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalOptions="Center" />

        <Entry x:Name="CurrentPasswordEntry"
               Placeholder="Contraseña actual"
               IsPassword="True"
               FontSize="18" />

        <Entry x:Name="NewPasswordEntry"
               Placeholder="Nueva contraseña"
               IsPassword="True"
               FontSize="18" />

        <Entry x:Name="ConfirmPasswordEntry"
               Placeholder="Confirmar nueva contraseña"
               IsPassword="True"
               FontSize="18" />

        <Button Text="Actualizar contraseña"
                Clicked="GuardarPasswordClicked"
                HeightRequest="55"
                CornerRadius="15"
                BackgroundColor="#C87F2F"
                TextColor="White"
                FontAttributes="Bold" />

    </VerticalStackLayout>

</ContentPage>
