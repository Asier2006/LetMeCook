<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MiniTFG"
             x:Class="MiniTFG.ProfilePage">

    <ContentPage.Resources>
        <ResourceDictionary>
            <TapGestureRecognizer x:Key="TapToCloseMenu"
                                  Tapped="CerrarMenuTapped" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">

        <!-- SCROLL PRINCIPAL -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- BANNER -->
                <Grid HeightRequest="160">
                    <Image x:Name="BannerImage"
                           Aspect="AspectFill"
                           HeightRequest="160" />
                </Grid>

                <!-- FOTO + NOMBRE + ESTRELLAS + BOTONES T/A -->
                <Grid ColumnDefinitions="Auto, *"
                      Margin="20,-40,20,0">

                    <VerticalStackLayout Grid.Column="0" Spacing="5">

                        <Border HeightRequest="100"
                                WidthRequest="100"
                                Stroke="White"
                                StrokeThickness="3"
                                BackgroundColor="Transparent"
                                StrokeShape="Ellipse">
                            <Image x:Name="ProfileImage"
                                   Aspect="AspectFill" />
                        </Border>

                        <Label x:Name="UsernameLabel"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="Black" />

                        <HorizontalStackLayout x:Name="EstrellasContainer"
                                               Spacing="4" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Grid.Column="1"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center"
                                           Spacing="10">

                        <Button x:Name="BtnTienda"
                                Text="T"
                                BackgroundColor="#E09A3F"
                                TextColor="White"
                                CornerRadius="10"
                                WidthRequest="40"
                                HeightRequest="40"
                                Clicked="AbrirTiendaClicked"/>

                        <Button x:Name="BtnAjustes"
                                Text="A"
                                BackgroundColor="#E09A3F"
                                TextColor="White"
                                CornerRadius="10"
                                WidthRequest="40"
                                HeightRequest="40"
                                Clicked="AbrirAjustesClicked"/>
                    </HorizontalStackLayout>

                </Grid>

                <!-- BOTONES RECTANGULARES -->
                <HorizontalStackLayout HorizontalOptions="Center"
                                       Margin="0,25,0,0">

                    <Button x:Name="BtnRecetas"
                            Text="Recetas"
                            BackgroundColor="#E09A3F"
                            TextColor="White"
                            WidthRequest="150"
                            HeightRequest="45"
                            Clicked="RecetasTabClicked"/>

                    <Button x:Name="BtnSobreMi"
                            Text="Sobre mí"
                            BackgroundColor="#E09A3F"
                            TextColor="White"
                            WidthRequest="150"
                            HeightRequest="45"
                            Clicked="SobreMiTabClicked"/>
                </HorizontalStackLayout>

                <BoxView HeightRequest="6"
                         BackgroundColor="#E09A3F"
                         CornerRadius="3"
                         Margin="20,10,20,10"/>

                <ContentView x:Name="ContentSwitcher"
                             Margin="20,10,20,0" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM BAR -->
        <Grid Grid.Row="1"
              BackgroundColor="#9C40F7"
              HeightRequest="65"
              Padding="5"
              ColumnDefinitions="*,*,*">

            <Button Grid.Column="0"
                    Text="Inicio"
                    ImageSource="home.png"
                    BackgroundColor="#9C40F7"
                    Clicked="InicioClicked" />

            <Button Grid.Column="1"
                    Text="Recetas"
                    ImageSource="recipes.png"
                    BackgroundColor="#9C40F7"
                    Clicked="RecetasClicked" />

            <Button Grid.Column="2"
                    Text="Perfil"
                    ImageSource="user.png"
                    BackgroundColor="#9C40F7"
                    Clicked="PerfilClicked" />

        </Grid>

        <!-- FONDO OSCURO -->
        <BoxView x:Name="Overlay"
                 Grid.RowSpan="2"
                 BackgroundColor="#00000066"
                 IsVisible="False"
                 Opacity="0">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="CerrarMenuTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- MENÚ LATERAL -->
        <Grid x:Name="SideMenu"
              Grid.RowSpan="2"
              BackgroundColor="White"
              WidthRequest="280"
              HorizontalOptions="End"
              TranslationX="300"
              Padding="20"
              IsVisible="False">

            <local:SettingsView />

        </Grid>

    </Grid>
</ContentPage>
