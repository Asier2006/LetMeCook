<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.UpdatePreferencesPage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25">

            <Label Text="Selecciona todas tus alergias y preferencias:"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <CollectionView ItemsSource="{Binding Preferencias}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border BackgroundColor="White"
                                Stroke="#C87F2F"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="10"
                                Margin="0,5">

                            <HorizontalStackLayout Spacing="10">

                                <CheckBox IsChecked="{Binding Seleccion}"
                                          Color="#FAC26C"
                                          VerticalOptions="Center" />

                                <Label Text="{Binding Nombre}"
                                       FontSize="18"
                                       TextColor="Black"
                                       VerticalOptions="Center" />

                            </HorizontalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Actualizar preferencias"
                    Clicked="UpdateClicked"
                    HeightRequest="55"
                    CornerRadius="15"
                    BackgroundColor="#C87F2F"
                    TextColor="White"
                    FontAttributes="Bold" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
