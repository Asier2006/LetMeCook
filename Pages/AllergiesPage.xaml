<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.AllergiesPage"
             BackgroundColor="white">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25">

            <!-- TÍTULO -->
            <Label Text="Selecciona todas tus alergias:"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <!-- LISTA DE ALÉRGENOS -->
            <CollectionView ItemsSource="{Binding Alergenos}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <HorizontalStackLayout Spacing="10" Padding="10">

                            <CheckBox IsChecked="{Binding Seleccion}"
                                      Color="#FAC26C"
                                      VerticalOptions="Center" />

                            <Label Text="{Binding Nombre}"
                                   FontSize="18"
                                   TextColor="Black"
                                   VerticalOptions="Center" />

                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- BOTÓN -->
            <Button Text="Siguiente"
                    x:Name="btnNext"
                    Clicked="NextClicked"
                    HeightRequest="55"
                    CornerRadius="15"
                    BackgroundColor="#C87F2F"
                    TextColor="White"
                    FontAttributes="Bold" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
