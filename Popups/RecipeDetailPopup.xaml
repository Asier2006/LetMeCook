<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="MiniTFG.RecipeDetailPopup">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18"
                             BackgroundColor="#9C40F7"
                             WidthRequest="330"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

            <!-- TÍTULO -->
            <Label x:Name="TituloLabel"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="White" />

            <!-- IMAGEN -->
            <Frame Padding="0"
                   CornerRadius="12"
                   HasShadow="True"
                   BackgroundColor="White">
                <Image x:Name="RecetaImage"
                       Aspect="AspectFill" />
            </Frame>

            <!-- DESCRIPCIÓN -->
            <Label Text="Descripción"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label x:Name="DescripcionLabel"
                   FontSize="15"
                   TextColor="White"
                   LineBreakMode="WordWrap" />

            <!-- ORIGEN -->
            <Label Text="Origen / Nacionalidad"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label x:Name="OrigenLabel"
                   FontSize="15"
                   TextColor="White"
                   LineBreakMode="WordWrap" />

            <!-- TIPO DE COCINA -->
            <Label Text="Tipo de cocina"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label x:Name="TipoCocinaLabel"
                   FontSize="15"
                   TextColor="White"
                   LineBreakMode="WordWrap" />

            <!-- INGREDIENTES -->
            <Label Text="Ingredientes principales"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label x:Name="IngredientesLabel"
                   FontSize="15"
                   TextColor="White"
                   LineBreakMode="WordWrap" />

            <!-- ALÉRGENOS -->
            <Label Text="Alergenos"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label x:Name="AlergenosLabel"
                   FontSize="15"
                   TextColor="White"
                   LineBreakMode="WordWrap" />

            <!-- PREFERENCIAS -->
            <Label Text="Preferencias alimentarias"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label x:Name="PreferenciasLabel"
                   FontSize="15"
                   TextColor="White"
                   LineBreakMode="WordWrap" />

            <!-- BOTÓN -->
            <Button Text="Let me cook!"
                    BackgroundColor="#7A1CCF"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Margin="0,10,0,0"
                    Clicked="OnLetMeCookClicked" />

        </VerticalStackLayout>
    </ScrollView>

</toolkit:Popup>
