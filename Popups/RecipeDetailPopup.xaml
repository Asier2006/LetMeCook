<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="MiniTFG.RecipeDetailPopup">

    <!-- CONTENEDOR CENTRADO -->
    <Grid VerticalOptions="Center"
          HorizontalOptions="Center"
          Padding="0">

        <ScrollView WidthRequest="330"
                    MaximumHeightRequest="600">

            <VerticalStackLayout Padding="20"
                                 Spacing="18"
                                 BackgroundColor="#FAC26C"
                                 WidthRequest="330"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <!-- TARJETA PRINCIPAL -->
                <Frame BackgroundColor="White"
                       CornerRadius="20"
                       Padding="20"
                       HasShadow="True">

                    <VerticalStackLayout Spacing="16">

                        <!-- TÍTULO -->
                        <Label x:Name="TituloLabel"
                               FontSize="26"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#E07A2D" />

                        <!-- IMAGEN -->
                        <Frame Padding="0"
                               CornerRadius="15"
                               HasShadow="True"
                               BackgroundColor="White">
                            <Image x:Name="RecetaImage"
                                   Aspect="AspectFill"
                                   HeightRequest="200" />
                        </Frame>

                        <!-- SEPARADOR -->
                        <BoxView HeightRequest="1"
                                 BackgroundColor="#E0A85A"
                                 Margin="0,10" />

                        <!-- BLOQUE DE INFORMACIÓN -->
                        <VerticalStackLayout Spacing="10">

                            <Label Text="Descripción"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#E07A2D" />
                            <Label x:Name="DescripcionLabel"
                                   FontSize="15"
                                   TextColor="Black" />

                            <Label Text="Origen / Nacionalidad"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#E07A2D" />
                            <Label x:Name="OrigenLabel"
                                   FontSize="15"
                                   TextColor="Black" />

                            <Label Text="Tipo de cocina"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#E07A2D" />
                            <Label x:Name="TipoCocinaLabel"
                                   FontSize="15"
                                   TextColor="Black" />

                            <Label Text="Ingredientes principales"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#E07A2D" />
                            <Label x:Name="IngredientesLabel"
                                   FontSize="15"
                                   TextColor="Black" />

                            <Label Text="Alergenos"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#E07A2D" />
                            <Label x:Name="AlergenosLabel"
                                   FontSize="15"
                                   TextColor="Black" />

                            <Label Text="Preferencias alimentarias"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#E07A2D" />
                            <Label x:Name="PreferenciasLabel"
                                   FontSize="15"
                                   TextColor="Black" />

                        </VerticalStackLayout>

                        <!-- BOTÓN -->
                        <Button Text="Let me cook!"
                                BackgroundColor="#E07A2D"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="50"
                                Margin="0,10,0,0"
                                Clicked="OnLetMeCookClicked" />

                    </VerticalStackLayout>

                </Frame>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</toolkit:Popup>
